/JOB
//NAME INPUT_WEAVADJ_VALUE
///FOLDERNAME FOLDER001
//POS
///NPOS 0,0,0,0,0,0
//INST
///DATE 2025/09/29 12:15
///ATTR SC,RW
///GROUP1 RB1
NOP
'scale and validate input value
'input is in 1/10mm in if panel
'so input 50 times 100 is 5000
'weavadj function expects
'1/1000 precision so 5000 is 5mm
SET I051 0
SET I052 0
SET I055 0
SET I056 0
TIMER T=0.50
*LOOP_INPUT
PAUSE
MSG "SET START / END WEAVING VALUE"
PAUSE
IFTHENEXP I051=0 OREXP I052=0
	 JUMP *LOOP_INPUT
ENDIF
TIMER T=0.50
SET I055  EXPRESS I051 * 100
SET I056  EXPRESS I052 * 100
TIMER T=0.50
'clamp value between 0 and 1000
IFTHENEXP I055>10000
	 SET I055 10000
ELSEIFEXP I055<0
	 SET I055 0
ENDIF
IFTHENEXP I056>10000
	 SET I056 10000
ELSEIFEXP I056<0
	 SET I056 0
ENDIF
END
