P00095=1116.664,160.280,463.887,0.0787,10.0067,0.0664
//INST
///DATE 2025/09/29 14:37
///ATTR SC,RW
///GROUP1 RB1
NOP
'GET X Y Z VALUE FOR BOTTOM END
'X
GETE D079 P095 (1)
SET I079  EXPRESS I078 * 100
IFTHENEXP I079>10000
	 SET I079 10000
ELSEIFEXP I079<-10000
	 SET I079 -10000
ENDIF
'Y
GETE D081 P095 (2)
SET I081  EXPRESS I080 * 100
IFTHENEXP I081>10000
	 SET I081 10000
ELSEIFEXP I081<-10000
	 SET I081 -10000
ENDIF
'Z
GETE D083 P095 (3)
SET I083  EXPRESS I082 * 100
IFTHENEXP I083>10000
	 SET I083 10000
ELSEIFEXP I083<-10000
	 SET I083 -10000
ENDIF
'ADD THE CORRECTIONS
ADD D079 I079
SETE P095 (1) D079
ADD D081 I081
SETE P095 (2) D081
ADD D083 I083
SETE P095 (3) D083
'SET TO 0
SET I078 0
SET I079 0
SET I080 0
SET I081 0
SET I082 0
SET I083 0
END
